rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Secure the users collection
    match /users/{userId} {
      // Users can only read, create, and update their own profile documents
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Cascade security to subcollections (e.g., trips, otp_attempts, activity)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Default deny for all other collections to ensure absolute security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}